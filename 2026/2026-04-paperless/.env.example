# Tailscale
TS_AUTHKEY=tskey-auth-xxxxx          # https://login.tailscale.com/admin/settings/keys
SERVICE=paperless                     # becomes your tailnet hostname

# Paperless-ngx
PAPERLESS_TIME_ZONE=America/New_York
PAPERLESS_OCR_LANGUAGE=eng
PAPERLESS_SECRET_KEY=change-me-to-a-long-random-string
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me

# PostgreSQL
POSTGRES_USER=paperless
POSTGRES_PASSWORD=change-me